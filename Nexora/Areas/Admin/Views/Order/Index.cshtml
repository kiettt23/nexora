@model List<Nexora.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="flex gap-2 mb-6 flex-wrap">
    <a asp-action="Index" class="btn btn-sm @(ViewBag.CurrentStatus == null ? "btn-primary" : "btn-ghost")">Tất cả</a>
    <a asp-action="Index" asp-route-status="@Nexora.Models.OrderStatus.Pending"
       class="btn btn-sm @(ViewBag.CurrentStatus != null && (Nexora.Models.OrderStatus)ViewBag.CurrentStatus == Nexora.Models.OrderStatus.Pending ? "btn-warning" : "btn-ghost")">Chờ xác nhận</a>
    <a asp-action="Index" asp-route-status="@Nexora.Models.OrderStatus.Confirmed"
       class="btn btn-sm @(ViewBag.CurrentStatus != null && (Nexora.Models.OrderStatus)ViewBag.CurrentStatus == Nexora.Models.OrderStatus.Confirmed ? "btn-info" : "btn-ghost")">Đã xác nhận</a>
    <a asp-action="Index" asp-route-status="@Nexora.Models.OrderStatus.Shipping"
       class="btn btn-sm @(ViewBag.CurrentStatus != null && (Nexora.Models.OrderStatus)ViewBag.CurrentStatus == Nexora.Models.OrderStatus.Shipping ? "btn-secondary" : "btn-ghost")">Đang giao</a>
    <a asp-action="Index" asp-route-status="@Nexora.Models.OrderStatus.Delivered"
       class="btn btn-sm @(ViewBag.CurrentStatus != null && (Nexora.Models.OrderStatus)ViewBag.CurrentStatus == Nexora.Models.OrderStatus.Delivered ? "btn-success" : "btn-ghost")">Đã giao</a>
    <a asp-action="Index" asp-route-status="@Nexora.Models.OrderStatus.Cancelled"
       class="btn btn-sm @(ViewBag.CurrentStatus != null && (Nexora.Models.OrderStatus)ViewBag.CurrentStatus == Nexora.Models.OrderStatus.Cancelled ? "btn-error" : "btn-ghost")">Đã hủy</a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-12 opacity-60">
        <p>Không có đơn hàng nào.</p>
    </div>
}
else
{
    <div class="overflow-x-auto bg-base-200 rounded-box shadow-sm">
        <table class="table">
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Ngày đặt</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    var statusClass = order.Status switch
                    {
                        Nexora.Models.OrderStatus.Pending => "badge-warning",
                        Nexora.Models.OrderStatus.Confirmed => "badge-info",
                        Nexora.Models.OrderStatus.Shipping => "badge-secondary",
                        Nexora.Models.OrderStatus.Delivered => "badge-success",
                        Nexora.Models.OrderStatus.Cancelled => "badge-error",
                        _ => ""
                    };
                    var statusLabel = order.Status switch
                    {
                        Nexora.Models.OrderStatus.Pending => "Chờ xác nhận",
                        Nexora.Models.OrderStatus.Confirmed => "Đã xác nhận",
                        Nexora.Models.OrderStatus.Shipping => "Đang giao",
                        Nexora.Models.OrderStatus.Delivered => "Đã giao",
                        Nexora.Models.OrderStatus.Cancelled => "Đã hủy",
                        _ => order.Status.ToString()
                    };
                    <tr class="hover">
                        <td class="font-mono">@order.OrderCode</td>
                        <td>@order.User.FullName</td>
                        <td>@order.TotalAmount.ToString("N0")₫</td>
                        <td><span class="badge badge-sm @statusClass">@statusLabel</span></td>
                        <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td><a asp-action="Detail" asp-route-id="@order.Id" class="btn btn-ghost btn-sm">Chi tiết</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
