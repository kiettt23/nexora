@model List<Nexora.Models.CartDetail>
@{
    ViewData["Title"] = "Giỏ hàng";
    var total = Model.Sum(cd => cd.UnitPrice * cd.Quantity);
}

<div class="container mx-auto max-w-6xl px-6 lg:px-8 py-8 lg:py-12">
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-8">Giỏ hàng</h1>

    @if (Model.Any())
    {
        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Cart items -->
            <div class="flex-1 space-y-4">
                @foreach (var item in Model)
                {
                    var mainImg = item.Product.Images.FirstOrDefault(i => i.IsMain) ?? item.Product.Images.FirstOrDefault();
                    <div class="flex items-center gap-5 bg-base-200/50 border border-base-300/30 rounded-2xl p-5 transition-all hover:border-base-300/60">
                        <!-- Image -->
                        <div class="w-20 h-20 rounded-xl overflow-hidden bg-base-300/20 flex-shrink-0">
                            @if (mainImg != null)
                            {
                                <img src="@mainImg.ImagePath" alt="@item.Product.Name" class="w-full h-full object-contain p-1" />
                            }
                        </div>

                        <!-- Info -->
                        <div class="flex-1 min-w-0">
                            <a asp-controller="Product" asp-action="Detail" asp-route-slug="@item.Product.Slug"
                               class="font-medium text-sm hover:text-primary transition-colors line-clamp-2">
                                @item.Product.Name
                            </a>
                            <p class="text-primary font-semibold text-sm mt-1">@item.UnitPrice.ToString("N0")₫</p>
                        </div>

                        <!-- Quantity -->
                        <form asp-action="Update" method="post" class="flex items-center">
                            <input type="hidden" name="cartDetailId" value="@item.Id" />
                            <div class="join border border-base-300/40 rounded-xl">
                                <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                        class="btn btn-ghost btn-xs join-item px-3">−</button>
                                <span class="flex items-center justify-center w-10 text-sm font-medium">@item.Quantity</span>
                                <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                        class="btn btn-ghost btn-xs join-item px-3">+</button>
                            </div>
                        </form>

                        <!-- Subtotal -->
                        <div class="text-right hidden sm:block min-w-[100px]">
                            <p class="font-bold text-sm">@((item.UnitPrice * item.Quantity).ToString("N0"))₫</p>
                        </div>

                        <!-- Remove -->
                        <form asp-action="Remove" method="post">
                            <input type="hidden" name="cartDetailId" value="@item.Id" />
                            <button type="submit" class="btn btn-ghost btn-sm btn-circle opacity-30 hover:opacity-100 hover:text-error transition-all">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </button>
                        </form>
                    </div>
                }
            </div>

            <!-- Order summary -->
            <div class="w-full lg:w-80">
                <div class="bg-base-200/50 border border-base-300/30 rounded-2xl p-6 sticky top-20">
                    <h3 class="text-xs font-semibold uppercase tracking-wider opacity-50 mb-5">Tóm tắt đơn hàng</h3>
                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between">
                            <span class="opacity-50">Tạm tính (@Model.Sum(cd => cd.Quantity) sản phẩm)</span>
                            <span>@total.ToString("N0")₫</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="opacity-50">Phí vận chuyển</span>
                            <span class="text-success font-medium">Miễn phí</span>
                        </div>
                    </div>
                    <div class="border-t border-base-300/30 my-5"></div>
                    <div class="flex justify-between font-bold text-lg mb-6">
                        <span>Tổng cộng</span>
                        <span class="text-primary">@total.ToString("N0")₫</span>
                    </div>
                    <a asp-controller="Order" asp-action="Checkout"
                       class="btn btn-primary w-full shadow-lg shadow-primary/20 hover:shadow-primary/40 hover:brightness-110 transition-all">
                        Đặt hàng
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-24">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20 mx-auto opacity-10 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
            </svg>
            <p class="text-lg opacity-50 mb-2">Giỏ hàng của bạn đang trống.</p>
            <p class="text-sm opacity-30 mb-8">Hãy khám phá các sản phẩm của chúng tôi.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary px-8 shadow-lg shadow-primary/20">Mua sắm ngay</a>
        </div>
    }
</div>
