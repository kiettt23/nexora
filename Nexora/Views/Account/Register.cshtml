@model Nexora.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="flex items-center justify-center min-h-[75vh] px-6 py-10">
    <div class="w-full max-w-md animate-fade-in">
        <div class="text-center mb-8">
            <a asp-controller="Home" asp-action="Index" class="inline-block text-2xl font-extrabold tracking-tight mb-4">
                <span class="text-gradient-brand">Nex</span>ora
            </a>
            <h2 class="text-2xl font-bold tracking-tight">Đăng ký tài khoản</h2>
            <p class="text-sm opacity-40 mt-1.5">Tạo tài khoản để mua sắm</p>
        </div>

        <div class="bg-base-200/50 border border-base-300/30 rounded-2xl p-7 shadow-xl shadow-black/5">
            <form asp-action="Register" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="bg-error/10 border border-error/20 text-error text-sm rounded-xl p-4 mb-6"></div>
                }

                <div class="space-y-4">
                    <div>
                        <label class="text-sm font-medium opacity-70 mb-1.5 block">Họ tên</label>
                        <input asp-for="FullName" type="text" placeholder="Nguyễn Văn A"
                               class="input input-bordered w-full bg-base-100/50 focus:bg-base-100 focus:border-primary/50 transition-all" />
                        <span asp-validation-for="FullName" class="text-error text-xs mt-1"></span>
                    </div>

                    <div>
                        <label class="text-sm font-medium opacity-70 mb-1.5 block">Email</label>
                        <input asp-for="Email" type="email" placeholder="email@example.com"
                               class="input input-bordered w-full bg-base-100/50 focus:bg-base-100 focus:border-primary/50 transition-all" />
                        <span asp-validation-for="Email" class="text-error text-xs mt-1"></span>
                    </div>

                    <div>
                        <label class="text-sm font-medium opacity-70 mb-1.5 block">Số điện thoại</label>
                        <input asp-for="Phone" type="tel" placeholder="0912345678"
                               class="input input-bordered w-full bg-base-100/50 focus:bg-base-100 focus:border-primary/50 transition-all" />
                        <span asp-validation-for="Phone" class="text-error text-xs mt-1"></span>
                    </div>

                    <div>
                        <label class="text-sm font-medium opacity-70 mb-1.5 block">Mật khẩu</label>
                        <input asp-for="Password" type="password" placeholder="••••••"
                               class="input input-bordered w-full bg-base-100/50 focus:bg-base-100 focus:border-primary/50 transition-all" />
                        <span asp-validation-for="Password" class="text-error text-xs mt-1"></span>
                    </div>

                    <div>
                        <label class="text-sm font-medium opacity-70 mb-1.5 block">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="••••••"
                               class="input input-bordered w-full bg-base-100/50 focus:bg-base-100 focus:border-primary/50 transition-all" />
                        <span asp-validation-for="ConfirmPassword" class="text-error text-xs mt-1"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-full shadow-lg shadow-primary/20 hover:shadow-primary/40 hover:brightness-110 transition-all">
                        Đăng ký
                    </button>
                </div>
            </form>
        </div>

        <p class="text-center text-sm mt-6 opacity-50">
            Đã có tài khoản?
            <a asp-action="Login" class="text-primary font-medium opacity-100 hover:underline">Đăng nhập</a>
        </p>
    </div>
</div>
