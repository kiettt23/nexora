@model Nexora.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container mx-auto max-w-7xl px-6 lg:px-8 py-8 lg:py-12">
    <div class="max-w-lg mx-auto">
        <div class="mb-6">
            <a asp-action="Profile" class="text-sm opacity-50 hover:opacity-100 hover:text-primary transition-all flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                Quay lại
            </a>
        </div>

        <h1 class="text-3xl font-bold tracking-tight mb-2">Đổi mật khẩu</h1>
        <p class="text-sm opacity-40 mb-8">Nhập mật khẩu hiện tại và mật khẩu mới</p>

        <div class="bg-base-200/60 border border-base-300/40 rounded-2xl p-6 lg:p-8">
            <form asp-action="ChangePassword" method="post">
                <div asp-validation-summary="All" class="text-error text-sm mb-4"></div>

                <div class="space-y-4">
                    <div class="form-control">
                        <label class="label"><span class="label-text font-medium">Mật khẩu hiện tại</span></label>
                        <input asp-for="CurrentPassword" class="input input-bordered w-full bg-base-100/50 focus:bg-base-100" />
                        <span asp-validation-for="CurrentPassword" class="text-error text-xs mt-1"></span>
                    </div>

                    <div class="form-control">
                        <label class="label"><span class="label-text font-medium">Mật khẩu mới</span></label>
                        <input asp-for="NewPassword" class="input input-bordered w-full bg-base-100/50 focus:bg-base-100" />
                        <span asp-validation-for="NewPassword" class="text-error text-xs mt-1"></span>
                    </div>

                    <div class="form-control">
                        <label class="label"><span class="label-text font-medium">Xác nhận mật khẩu mới</span></label>
                        <input asp-for="ConfirmPassword" class="input input-bordered w-full bg-base-100/50 focus:bg-base-100" />
                        <span asp-validation-for="ConfirmPassword" class="text-error text-xs mt-1"></span>
                    </div>
                </div>

                <div class="mt-6 flex gap-3">
                    <button type="submit" class="btn btn-primary">Đổi mật khẩu</button>
                    <a asp-action="Profile" class="btn btn-ghost">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
