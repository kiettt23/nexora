@model Nexora.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="container mx-auto max-w-7xl px-6 lg:px-8 py-8 lg:py-12">
    <div class="max-w-2xl mx-auto">
        <h1 class="text-3xl font-bold tracking-tight mb-2">Thông tin cá nhân</h1>
        <p class="text-sm opacity-40 mb-8">Quản lý thông tin tài khoản của bạn</p>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span>@TempData["Success"]</span>
            </div>
        }

        <div class="bg-base-200/60 border border-base-300/40 rounded-2xl p-6 lg:p-8 mb-6">
            <h2 class="text-lg font-semibold mb-5">Thông tin cơ bản</h2>
            <form asp-action="Profile" method="post">
                <div asp-validation-summary="All" class="text-error text-sm mb-4"></div>

                <div class="space-y-4">
                    <div class="form-control">
                        <label class="label"><span class="label-text font-medium">Họ tên</span></label>
                        <input asp-for="FullName" class="input input-bordered w-full bg-base-100/50 focus:bg-base-100" />
                        <span asp-validation-for="FullName" class="text-error text-xs mt-1"></span>
                    </div>

                    <div class="form-control">
                        <label class="label"><span class="label-text font-medium">Email</span></label>
                        <input asp-for="Email" class="input input-bordered w-full bg-base-100/50" readonly />
                        <span class="text-xs opacity-40 mt-1">Email không thể thay đổi</span>
                    </div>

                    <div class="form-control">
                        <label class="label"><span class="label-text font-medium">Số điện thoại</span></label>
                        <input asp-for="Phone" class="input input-bordered w-full bg-base-100/50 focus:bg-base-100" />
                        <span asp-validation-for="Phone" class="text-error text-xs mt-1"></span>
                    </div>

                    <div class="form-control">
                        <label class="label"><span class="label-text font-medium">Địa chỉ</span></label>
                        <input asp-for="Address" class="input input-bordered w-full bg-base-100/50 focus:bg-base-100" />
                        <span asp-validation-for="Address" class="text-error text-xs mt-1"></span>
                    </div>
                </div>

                <div class="mt-6">
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>

        <div class="bg-base-200/60 border border-base-300/40 rounded-2xl p-6 lg:p-8">
            <h2 class="text-lg font-semibold mb-2">Bảo mật</h2>
            <p class="text-sm opacity-40 mb-4">Thay đổi mật khẩu đăng nhập</p>
            <a asp-action="ChangePassword" class="btn btn-outline btn-sm">Đổi mật khẩu</a>
        </div>
    </div>
</div>
