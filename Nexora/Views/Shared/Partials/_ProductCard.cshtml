@model Nexora.Models.Product

@{
    var isNew = (DateTime.UtcNow - Model.CreatedAt).TotalDays <= 7;
}

<a asp-controller="Product" asp-action="Detail" asp-route-slug="@Model.Slug"
   class="group flex flex-col bg-base-200/50 rounded-xl border border-base-300/30 overflow-hidden
          hover:border-primary/30 hover:shadow-xl hover:shadow-primary/10 hover:-translate-y-1
          transition-all duration-300 card-premium">
    <!-- Image -->
    <div class="relative aspect-square bg-base-300/20 overflow-hidden">
        @if (Model.Images.Any(i => i.IsMain))
        {
            <img src="@Model.Images.First(i => i.IsMain).ImagePath" alt="@Model.Name"
                 loading="lazy"
                 class="w-full h-full object-contain p-3 group-hover:scale-105 transition-transform duration-500" />
        }
        else if (Model.Images.Any())
        {
            <img src="@Model.Images.First().ImagePath" alt="@Model.Name"
                 loading="lazy"
                 class="w-full h-full object-contain p-3 group-hover:scale-105 transition-transform duration-500" />
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 opacity-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </div>
        }

        <!-- Gradient overlay on hover -->
        <div class="absolute inset-0 bg-gradient-to-t from-base-100/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>

        <!-- Badges -->
        <div class="absolute top-2 left-2 flex flex-col gap-1">
            @if (Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.Price)
            {
                var discount = (int)((1 - Model.Price / Model.OriginalPrice.Value) * 100);
                <span class="bg-error text-error-content text-[10px] font-bold px-1.5 py-0.5 rounded-md shadow-sm">
                    -@discount%
                </span>
            }
            @if (isNew)
            {
                <span class="bg-info text-info-content text-[10px] font-bold px-1.5 py-0.5 rounded-md shadow-sm">
                    Mới
                </span>
            }
        </div>

        <!-- Quick action hint -->
        <div class="absolute bottom-2 right-2 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-1 group-hover:translate-y-0">
            <span class="bg-primary text-primary-content text-[10px] font-semibold px-2 py-1 rounded-lg shadow-md">
                Xem chi tiết
            </span>
        </div>
    </div>

    <!-- Info -->
    <div class="flex flex-col flex-1 p-3.5 gap-1.5">
        <h3 class="text-sm font-medium leading-snug line-clamp-2 min-h-[2.5rem] group-hover:text-primary transition-colors">
            @Model.Name
        </h3>
        @if (!string.IsNullOrEmpty(Model.Brand))
        {
            <p class="text-[11px] opacity-35 font-medium">@Model.Brand</p>
        }
        <div class="mt-auto pt-1.5 flex items-baseline gap-2 flex-wrap">
            <span class="text-primary font-extrabold text-base">@Model.Price.ToString("N0")₫</span>
            @if (Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.Price)
            {
                <span class="text-[11px] line-through opacity-30">@Model.OriginalPrice.Value.ToString("N0")₫</span>
            }
        </div>
    </div>
</a>
