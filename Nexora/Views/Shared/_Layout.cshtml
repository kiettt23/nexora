<!DOCTYPE html>
<html lang="vi" data-theme="nexora-dark"
      x-data="{ darkMode: localStorage.getItem('theme') !== 'light' }"
      x-init="$watch('darkMode', v => localStorage.setItem('theme', v ? 'dark' : 'light'))"
      :data-theme="darkMode ? 'nexora-dark' : 'nexora-light'">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Nexora</title>
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "Nexora — Công nghệ thế hệ mới. Điện thoại, laptop, tablet & phụ kiện chính hãng giá tốt.")" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />

    <!-- Tailwind + DaisyUI -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="min-h-screen bg-base-100 text-base-content font-sans antialiased">

    <!-- Promo bar -->
    <div class="bg-gradient-to-r from-primary/10 via-primary/5 to-accent/10 border-b border-primary/10">
        <div class="container mx-auto max-w-7xl px-6 lg:px-8">
            <div class="flex items-center justify-center gap-6 h-9 text-[11px] sm:text-xs">
                <span class="flex items-center gap-1.5 opacity-70">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" /></svg>
                    <span class="font-medium">Miễn phí giao hàng đơn từ <span class="text-primary font-semibold">500K</span></span>
                </span>
                <span class="hidden sm:flex items-center gap-1.5 opacity-70">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                    <span class="font-medium">Chính hãng 100%</span>
                </span>
                <span class="hidden md:flex items-center gap-1.5 opacity-70">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-info" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                    <span class="font-medium">Đổi trả <span class="text-primary font-semibold">30 ngày</span></span>
                </span>
            </div>
        </div>
    </div>

    <!-- Navbar -->
    <header class="sticky top-0 z-50 bg-base-100/80 backdrop-blur-xl border-b border-base-300/20">
        <div class="container mx-auto max-w-7xl px-6 lg:px-8">
            <div class="flex items-center justify-between h-14">
                <!-- Left: Logo + Nav -->
                <div class="flex items-center gap-6">
                    <a asp-controller="Home" asp-action="Index" class="text-xl font-extrabold tracking-tight shrink-0">
                        <span class="text-gradient-brand">Nex</span><span>ora</span>
                    </a>
                    <nav class="hidden lg:flex items-center gap-0.5 text-sm font-medium">
                        <a asp-controller="Home" asp-action="Index" class="px-3 py-1.5 rounded-lg opacity-70 hover:opacity-100 hover:bg-base-200/80 transition-all">Trang chủ</a>
                        <a asp-controller="Product" asp-action="Index" class="px-3 py-1.5 rounded-lg opacity-70 hover:opacity-100 hover:bg-base-200/80 transition-all">Sản phẩm</a>
                    </nav>
                </div>

                <!-- Right: Actions -->
                <div class="flex items-center gap-1.5">
                    <!-- Theme toggle -->
                    <label class="swap swap-rotate btn btn-ghost btn-circle btn-sm">
                        <input type="checkbox" x-model="darkMode" />
                        <svg class="swap-off h-[18px] w-[18px] fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z" />
                        </svg>
                        <svg class="swap-on h-[18px] w-[18px] fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z" />
                        </svg>
                    </label>

                    <!-- Cart -->
                    <a asp-controller="Cart" asp-action="Index" class="btn btn-ghost btn-circle btn-sm">
                        <div class="indicator">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
                            </svg>
                            <span class="badge badge-sm badge-primary indicator-item text-[10px]" id="cart-count">0</span>
                        </div>
                    </a>

                    <!-- User menu -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown dropdown-end">
                            <div tabindex="0" role="button" class="btn btn-ghost btn-circle btn-sm avatar placeholder">
                                <div class="bg-primary/20 text-primary w-8 rounded-full">
                                    <span class="text-xs font-bold">@User.Identity.Name?.Substring(0, 1).ToUpper()</span>
                                </div>
                            </div>
                            <ul tabindex="0" class="menu menu-sm dropdown-content bg-base-200 rounded-xl z-[1] mt-3 w-52 p-2 shadow-xl border border-base-300/30">
                                @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                                {
                                    <li><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Quản trị</a></li>
                                    <li class="border-b border-base-300/30 mb-1"></li>
                                }
                                <li><a asp-controller="Account" asp-action="Profile">Thông tin cá nhân</a></li>
                                <li><a asp-controller="Order" asp-action="MyOrders">Đơn hàng của tôi</a></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="text-error">Đăng xuất</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"
                           class="ml-1 px-4 py-1.5 rounded-lg bg-primary text-primary-content text-sm font-semibold shadow-md shadow-primary/20 hover:shadow-primary/30 hover:brightness-110 transition-all">Đăng nhập</a>
                    }

                    <!-- Mobile menu -->
                    <div class="dropdown dropdown-end lg:hidden">
                        <div tabindex="0" role="button" class="btn btn-ghost btn-sm" aria-label="Menu">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
                            </svg>
                        </div>
                        <ul tabindex="0" class="menu menu-sm dropdown-content bg-base-200 rounded-xl z-[1] mt-3 w-52 p-2 shadow-xl border border-base-300/30">
                            <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                            <li><a asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Toast notifications -->
    @await Html.PartialAsync("Partials/_Toast")

    <!-- Main content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="border-t border-base-300/20 mt-auto bg-base-200/30">
        <div class="container mx-auto max-w-7xl px-6 lg:px-8 pt-14 pb-8">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
                <!-- Brand -->
                <div class="md:col-span-1">
                    <h3 class="text-xl font-extrabold mb-3"><span class="text-gradient-brand">Nex</span>ora</h3>
                    <p class="text-sm opacity-40 leading-relaxed max-w-xs mb-5">Công nghệ thế hệ mới. Điện thoại, laptop, tablet & phụ kiện chính hãng với giá tốt nhất.</p>
                    <div class="flex items-center gap-3">
                        <a href="#" class="w-9 h-9 rounded-lg bg-base-300/30 flex items-center justify-center hover:bg-primary/20 hover:text-primary transition-all" aria-label="Facebook">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                        </a>
                        <a href="#" class="w-9 h-9 rounded-lg bg-base-300/30 flex items-center justify-center hover:bg-primary/20 hover:text-primary transition-all" aria-label="YouTube">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><polygon fill="#09090B" points="9.545 15.568 15.818 12 9.545 8.432"/></svg>
                        </a>
                        <a href="#" class="w-9 h-9 rounded-lg bg-base-300/30 flex items-center justify-center hover:bg-primary/20 hover:text-primary transition-all" aria-label="Zalo">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.568 8.16c-.18-.04-.36-.04-.54-.04-1.8.04-3.32 1.16-3.96 2.84-.08.2-.12.4-.16.6V8.2h-2.44v9.6h2.6v-4c0-.56.04-1.08.2-1.6.44-1.24 1.48-2.08 2.8-2.12.36 0 .72.04 1.08.12l.4-2z"/></svg>
                        </a>
                    </div>
                </div>

                <!-- Links -->
                <div>
                    <h4 class="text-xs font-semibold uppercase tracking-wider opacity-50 mb-4">Sản phẩm</h4>
                    <ul class="space-y-2.5 text-sm">
                        <li><a asp-controller="Product" asp-action="Index" asp-route-category="dien-thoai" class="opacity-50 hover:opacity-100 hover:text-primary transition-all">Điện thoại</a></li>
                        <li><a asp-controller="Product" asp-action="Index" asp-route-category="laptop" class="opacity-50 hover:opacity-100 hover:text-primary transition-all">Laptop</a></li>
                        <li><a asp-controller="Product" asp-action="Index" asp-route-category="tablet" class="opacity-50 hover:opacity-100 hover:text-primary transition-all">Tablet</a></li>
                        <li><a asp-controller="Product" asp-action="Index" asp-route-category="phu-kien" class="opacity-50 hover:opacity-100 hover:text-primary transition-all">Phụ kiện</a></li>
                    </ul>
                </div>

                <!-- Support -->
                <div>
                    <h4 class="text-xs font-semibold uppercase tracking-wider opacity-50 mb-4">Hỗ trợ</h4>
                    <ul class="space-y-2.5 text-sm">
                        <li><a href="#" class="opacity-50 hover:opacity-100 hover:text-primary transition-all">Chính sách bảo hành</a></li>
                        <li><a href="#" class="opacity-50 hover:opacity-100 hover:text-primary transition-all">Chính sách đổi trả</a></li>
                        <li><a href="#" class="opacity-50 hover:opacity-100 hover:text-primary transition-all">Hướng dẫn mua hàng</a></li>
                        <li><a href="#" class="opacity-50 hover:opacity-100 hover:text-primary transition-all">Câu hỏi thường gặp</a></li>
                    </ul>
                </div>

                <!-- Contact -->
                <div>
                    <h4 class="text-xs font-semibold uppercase tracking-wider opacity-50 mb-4">Liên hệ</h4>
                    <ul class="space-y-2.5 text-sm">
                        <li class="flex items-center gap-2 opacity-50">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                            contact@nexora.vn
                        </li>
                        <li class="flex items-center gap-2 opacity-50">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                            0123 456 789
                        </li>
                        <li class="flex items-center gap-2 opacity-50">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            TP. Hồ Chí Minh, Việt Nam
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Payment methods & copyright -->
            <div class="border-t border-base-300/20 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
                <p class="text-xs opacity-30">&copy; 2026 Nexora. All rights reserved.</p>
                <div class="flex items-center gap-3 opacity-30">
                    <span class="text-[10px] uppercase tracking-wider">Thanh toán:</span>
                    <span class="text-xs font-semibold">VISA</span>
                    <span class="text-xs font-semibold">MasterCard</span>
                    <span class="text-xs font-semibold">MoMo</span>
                    <span class="text-xs font-semibold">ZaloPay</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
