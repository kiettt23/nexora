@model ErrorViewModel
@{
    ViewData["Title"] = "Loi";
}

<div class="flex items-center justify-center min-h-[60vh]">
    <div class="text-center">
        <h1 class="text-6xl font-bold text-error mb-4">Oops!</h1>
        <p class="text-xl mb-2">Da xay ra loi khi xu ly yeu cau cua ban.</p>
        @if (Model.ShowRequestId)
        {
            <p class="text-sm opacity-50 mb-6">Request ID: <code class="font-mono">@Model.RequestId</code></p>
        }
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Ve trang chu</a>
    </div>
</div>
