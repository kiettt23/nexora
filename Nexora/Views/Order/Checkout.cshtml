@model Nexora.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
    var cartDetails = ViewBag.CartDetails as List<Nexora.Models.CartDetail>;
    var total = (decimal)ViewBag.Total;
}

<div class="container mx-auto max-w-6xl px-6 lg:px-8 py-10 lg:py-14">
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-10">Thanh toán</h1>

    <div class="flex flex-col lg:flex-row gap-10">
        <!-- Checkout form -->
        <div class="flex-1">
            <form asp-action="Checkout" method="post" class="bg-base-200/50 border border-base-300/30 rounded-2xl p-8">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="bg-error/10 border border-error/20 text-error text-sm rounded-xl p-4 mb-6"></div>
                }

                <div class="space-y-5">
                    <div>
                        <label class="text-sm font-medium opacity-70 mb-2 block">Họ tên người nhận</label>
                        <input asp-for="FullName" class="input input-bordered w-full bg-base-100/50 focus:bg-base-100" />
                        <span asp-validation-for="FullName" class="text-error text-xs mt-1"></span>
                    </div>

                    <div>
                        <label class="text-sm font-medium opacity-70 mb-2 block">Số điện thoại</label>
                        <input asp-for="Phone" class="input input-bordered w-full bg-base-100/50 focus:bg-base-100" />
                        <span asp-validation-for="Phone" class="text-error text-xs mt-1"></span>
                    </div>

                    <div>
                        <label class="text-sm font-medium opacity-70 mb-2 block">Địa chỉ giao hàng</label>
                        <textarea asp-for="Address" class="textarea textarea-bordered w-full bg-base-100/50 focus:bg-base-100" rows="3"></textarea>
                        <span asp-validation-for="Address" class="text-error text-xs mt-1"></span>
                    </div>

                    <div>
                        <label class="text-sm font-medium opacity-70 mb-2 block">Ghi chú (không bắt buộc)</label>
                        <textarea asp-for="Note" class="textarea textarea-bordered w-full bg-base-100/50 focus:bg-base-100" rows="2"></textarea>
                    </div>

                    <div class="bg-base-300/20 border border-base-300/30 rounded-xl p-4">
                        <p class="text-xs font-semibold uppercase tracking-wider opacity-50 mb-3">Phương thức thanh toán</p>
                        <label class="flex items-center gap-3 cursor-pointer">
                            <input type="radio" class="radio radio-primary radio-sm" checked disabled />
                            <span class="text-sm">Thanh toán khi nhận hàng (COD)</span>
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary w-full btn-lg shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all">
                        Đặt hàng — @total.ToString("N0")₫
                    </button>
                </div>
            </form>
        </div>

        <!-- Order summary -->
        <div class="w-full lg:w-96">
            <div class="bg-base-200/50 border border-base-300/30 rounded-2xl p-6 sticky top-20">
                <h3 class="text-xs font-semibold uppercase tracking-wider opacity-50 mb-5">Đơn hàng của bạn</h3>
                @if (cartDetails != null)
                {
                    <div class="space-y-4">
                        @foreach (var item in cartDetails)
                        {
                            <div class="flex justify-between items-center">
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm line-clamp-1 font-medium">@item.Product.Name</p>
                                    <p class="text-xs opacity-40 mt-0.5">x@item.Quantity</p>
                                </div>
                                <span class="text-sm font-semibold ml-4 flex-shrink-0">@((item.UnitPrice * item.Quantity).ToString("N0"))₫</span>
                            </div>
                        }
                    </div>
                }
                <div class="border-t border-base-300/30 my-5"></div>
                <div class="flex justify-between font-bold text-lg">
                    <span>Tổng cộng</span>
                    <span class="text-primary">@total.ToString("N0")₫</span>
                </div>
            </div>
        </div>
    </div>
</div>
