@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero -->
<section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-base-200 via-base-100 to-base-100"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary/10 via-transparent to-transparent"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-primary/5 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute top-20 right-[10%] w-[200px] h-[200px] bg-accent/5 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-0 left-[15%] w-[300px] h-[200px] bg-secondary/5 rounded-full blur-3xl"></div>

    <div class="container mx-auto max-w-7xl px-6 lg:px-8 relative z-10">
        <div class="max-w-2xl mx-auto text-center py-14 lg:py-20">
            <div class="inline-flex items-center gap-2 mb-5 px-3.5 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-sm animate-fade-in">
                <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
                <span class="text-primary font-medium text-xs">Ưu đãi đặc biệt tháng 3</span>
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.08] mb-5 tracking-tight animate-slide-up">
                Công nghệ<br/><span class="text-gradient-brand">thế hệ mới</span>
            </h1>
            <p class="text-base md:text-lg opacity-50 mb-7 max-w-md mx-auto leading-relaxed animate-fade-in">
                Khám phá điện thoại, laptop, tablet và phụ kiện công nghệ chính hãng với giá tốt nhất.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center animate-slide-up">
                <a asp-controller="Product" asp-action="Index"
                   class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-xl bg-primary text-primary-content font-semibold text-sm shadow-lg shadow-primary/25 hover:shadow-primary/40 hover:brightness-110 hover:-translate-y-0.5 transition-all duration-300">
                    Mua sắm ngay
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                </a>
                <a asp-controller="Product" asp-action="Index" asp-route-category="dien-thoai"
                   class="inline-flex items-center justify-center px-7 py-3 rounded-xl border border-base-content/15 font-semibold text-sm hover:border-primary/40 hover:bg-primary/5 hover:-translate-y-0.5 transition-all duration-300">
                    Xem điện thoại
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Categories -->
<section class="py-10 lg:py-12 px-6 lg:px-8">
    <div class="container mx-auto max-w-7xl">
        <div class="text-center mb-8">
            <h2 class="text-2xl md:text-3xl font-bold mb-1.5">Danh mục sản phẩm</h2>
            <p class="opacity-40 text-sm">Chọn danh mục bạn quan tâm</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 lg:gap-4">
            @{
                var categories = new[] {
                    ("dien-thoai", "Điện thoại", "Smartphone chính hãng", "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"),
                    ("laptop", "Laptop", "Văn phòng & Gaming", "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"),
                    ("tablet", "Tablet", "Máy tính bảng", "M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"),
                    ("phu-kien", "Phụ kiện", "Cáp, sạc, chuột, ốp...", "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z")
                };
            }
            @foreach (var (slug, name, desc, icon) in categories)
            {
                <a asp-controller="Product" asp-action="Index" asp-route-category="@slug"
                   class="group flex flex-col items-center text-center p-5 lg:p-6 rounded-2xl bg-base-200/50 border border-base-300/30
                          hover:bg-base-200 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-1
                          transition-all duration-300 card-premium">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-3 group-hover:bg-primary/20 group-hover:scale-110 transition-all duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="@icon" />
                        </svg>
                    </div>
                    <h3 class="font-semibold text-sm mb-0.5">@name</h3>
                    <p class="text-xs opacity-40">@desc</p>
                </a>
            }
        </div>
    </div>
</section>

<!-- Flash Sale / Deal Hot -->
<section class="py-10 lg:py-12 px-6 lg:px-8" x-data="flashSaleTimer()" x-init="startTimer()">
    <div class="container mx-auto max-w-7xl">
        <div class="relative rounded-2xl bg-gradient-to-r from-error/10 via-error/5 to-primary/10 border border-error/20 p-6 lg:p-8 overflow-hidden">
            <!-- Decorative -->
            <div class="absolute top-0 right-0 w-40 h-40 bg-error/10 rounded-full blur-3xl"></div>
            <div class="absolute bottom-0 left-0 w-32 h-32 bg-primary/10 rounded-full blur-3xl"></div>

            <div class="relative z-10">
                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
                    <div class="flex items-center gap-3">
                        <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-error/20">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                        </div>
                        <div>
                            <h2 class="text-xl md:text-2xl font-extrabold">
                                <span class="text-error">Deal</span> Hot Hôm Nay
                            </h2>
                            <p class="text-xs opacity-50">Giảm giá cực sốc - Số lượng có hạn</p>
                        </div>
                    </div>
                    <!-- Countdown -->
                    <div class="flex items-center gap-2">
                        <span class="text-xs opacity-50 mr-1">Kết thúc sau:</span>
                        <div class="flex items-center gap-1.5">
                            <div class="bg-base-100/80 rounded-lg px-2.5 py-1.5 min-w-[40px] text-center border border-base-300/30">
                                <span class="text-sm font-bold text-error" x-text="hours">00</span>
                            </div>
                            <span class="text-error font-bold text-xs">:</span>
                            <div class="bg-base-100/80 rounded-lg px-2.5 py-1.5 min-w-[40px] text-center border border-base-300/30">
                                <span class="text-sm font-bold text-error" x-text="minutes">00</span>
                            </div>
                            <span class="text-error font-bold text-xs">:</span>
                            <div class="bg-base-100/80 rounded-lg px-2.5 py-1.5 min-w-[40px] text-center border border-base-300/30">
                                <span class="text-sm font-bold text-error" x-text="seconds">00</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sale products preview - show featured products with discount -->
                @{
                    var featured = ViewBag.FeaturedProducts as List<Nexora.Models.Product>;
                    var saleProducts = featured?.Where(p => p.OriginalPrice.HasValue && p.OriginalPrice > p.Price).Take(4).ToList();
                }
                @if (saleProducts != null && saleProducts.Any())
                {
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 lg:gap-4">
                        @foreach (var product in saleProducts)
                        {
                            <partial name="Partials/_ProductCard" model="product" />
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-6 opacity-50 text-sm">
                        <p>Đang cập nhật sản phẩm khuyến mãi...</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- New Arrivals -->
<section class="py-10 lg:py-12 px-6 lg:px-8">
    <div class="container mx-auto max-w-7xl">
        <div class="flex items-end justify-between mb-6">
            <div>
                <h2 class="text-2xl md:text-3xl font-bold mb-1">Hàng mới về</h2>
                <p class="opacity-40 text-sm">Sản phẩm vừa cập nhật mới nhất</p>
            </div>
            <a asp-controller="Product" asp-action="Index"
               class="hidden md:inline-flex items-center gap-1.5 text-sm font-medium opacity-50 hover:opacity-100 hover:text-primary transition-all">
                Xem tất cả
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </a>
        </div>
        @{
            var newArrivals = ViewBag.NewArrivals as List<Nexora.Models.Product>;
        }
        @if (newArrivals != null && newArrivals.Any())
        {
            <div class="relative">
                <div class="flex gap-3 lg:gap-4 overflow-x-auto scrollbar-hide pb-2 snap-x snap-mandatory">
                    @foreach (var product in newArrivals)
                    {
                        <div class="w-[180px] md:w-[220px] flex-shrink-0 snap-start">
                            <partial name="Partials/_ProductCard" model="product" />
                        </div>
                    }
                </div>
            </div>
            <div class="text-center mt-6 md:hidden">
                <a asp-controller="Product" asp-action="Index"
                   class="inline-flex px-6 py-2.5 rounded-xl border border-primary/30 text-primary text-sm font-medium hover:bg-primary/10 transition-all">
                    Xem tất cả sản phẩm mới
                </a>
            </div>
        }
    </div>
</section>

<!-- Featured Brands -->
<section class="py-8 lg:py-10 px-6 lg:px-8">
    <div class="container mx-auto max-w-7xl">
        <div class="text-center mb-6">
            <h2 class="text-lg md:text-xl font-bold opacity-80">Thương hiệu nổi bật</h2>
        </div>
        <div class="flex items-center justify-center flex-wrap gap-4 lg:gap-6">
            @{
                var brandList = new[] {
                    ("Apple", "apple"),
                    ("Samsung", "samsung"),
                    ("Xiaomi", "xiaomi"),
                    ("OPPO", "oppo"),
                    ("Dell", "dell"),
                    ("ASUS", "asus"),
                    ("Lenovo", "lenovo"),
                    ("Sony", "sony")
                };
            }
            @foreach (var (brandName, brandSlug) in brandList)
            {
                <a asp-controller="Product" asp-action="Index" asp-route-brand="@brandName"
                   class="group flex items-center justify-center px-5 py-3 rounded-xl bg-base-200/40 border border-base-300/20
                          hover:border-primary/30 hover:bg-primary/5 hover:shadow-md hover:shadow-primary/5
                          transition-all duration-300 min-w-[100px]">
                    <span class="text-sm font-semibold opacity-50 group-hover:opacity-100 group-hover:text-primary transition-all">@brandName</span>
                </a>
            }
        </div>
    </div>
</section>

