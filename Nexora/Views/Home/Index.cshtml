<!-- Featured Products -->
<section class="py-10 lg:py-12 px-6 lg:px-8 bg-base-200/20">
    <div class="container mx-auto max-w-7xl">
        <div class="flex items-end justify-between mb-6">
            <div>
                <h2 class="text-2xl md:text-3xl font-bold mb-1">Sản phẩm nổi bật</h2>
                <p class="opacity-40 text-sm">Những sản phẩm được yêu thích nhất</p>
            </div>
            <a asp-controller="Product" asp-action="Index"
               class="hidden md:inline-flex items-center gap-1.5 text-sm font-medium opacity-50 hover:opacity-100 hover:text-primary transition-all">
                Xem tất cả
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </a>
        </div>
        @if (featured != null && featured.Any())
        {
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 lg:gap-4">
                @foreach (var product in featured)
                {
                    <partial name="Partials/_ProductCard" model="product" />
                }
            </div>
            <div class="text-center mt-8 md:hidden">
                <a asp-controller="Product" asp-action="Index"
                   class="inline-flex px-6 py-2.5 rounded-xl border border-primary/30 text-primary text-sm font-medium hover:bg-primary/10 transition-all">
                    Xem tất cả sản phẩm
                </a>
            </div>
        }
        else
        {
            <p class="text-center opacity-50 py-8">Chưa có sản phẩm nào.</p>
        }
    </div>
</section>

<!-- Browse by Category (Tabbed) -->
<section class="py-10 lg:py-12 px-6 lg:px-8" x-data="{ activeTab: 0 }">
    <div class="container mx-auto max-w-7xl">
        <div class="text-center mb-8">
            <h2 class="text-2xl md:text-3xl font-bold mb-1.5">Khám phá theo danh mục</h2>
            <p class="opacity-40 text-sm">Duyệt sản phẩm theo từng loại</p>
        </div>
        @{
            var productsByCategory = ViewBag.ProductsByCategory as Dictionary<string, List<Nexora.Models.Product>>;
        }
        @if (productsByCategory != null && productsByCategory.Any())
        {
            var catEntries = productsByCategory.Select((kvp, i) => new { Name = kvp.Key, Products = kvp.Value, Index = i }).ToList();

            <!-- Tabs -->
            <div class="flex items-center justify-center gap-2 mb-6 flex-wrap">
                @foreach (var entry in catEntries)
                {
                    <button @@click="activeTab = @entry.Index"
                            :class="activeTab === @entry.Index ? 'bg-primary text-primary-content shadow-lg shadow-primary/20' : 'bg-base-200/50 border-base-300/30 hover:border-primary/30 hover:bg-primary/5'"
                            class="px-4 py-2 rounded-xl text-sm font-medium border transition-all duration-200 cursor-pointer">
                        @entry.Name
                    </button>
                }
            </div>

            <!-- Tab Content -->
            @foreach (var entry in catEntries)
            {
                <div x-show="activeTab === @entry.Index" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 lg:gap-4">
                        @foreach (var product in entry.Products)
                        {
                            <partial name="Partials/_ProductCard" model="product" />
                        }
                    </div>
                    <div class="text-center mt-6">
                        <a asp-controller="Product" asp-action="Index"
                           class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-xl border border-primary/30 text-primary text-sm font-medium hover:bg-primary/10 transition-all">
                            Xem tất cả @entry.Name
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</section>

<!-- Why choose Nexora -->
