@model List<Nexora.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";
    var categories = ViewBag.Categories as List<Nexora.Models.Category>;
    var brands = ViewBag.Brands as List<string>;
}

<div class="container mx-auto max-w-7xl px-6 lg:px-8 py-8 lg:py-12">
    <div class="mb-8">
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight">Sản phẩm</h1>
        <p class="text-sm opacity-40 mt-1">Khám phá hàng ngàn sản phẩm công nghệ chính hãng</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
        <!-- Sidebar -->
        <aside class="w-full lg:w-60 flex-shrink-0">
            <div class="bg-base-200/60 border border-base-300/40 rounded-2xl p-5 space-y-6 sticky top-20">
                <!-- Search -->
                <div class="form-control">
                    <input type="text" placeholder="Tìm kiếm..."
                           class="input input-bordered input-sm w-full bg-base-100/50 focus:bg-base-100"
                           id="product-search"
                           value="@ViewBag.CurrentSearch" />
                </div>

                <!-- Categories -->
                <div>
                    <h4 class="text-xs font-semibold uppercase tracking-wider opacity-50 mb-3">Danh mục</h4>
                    <div class="space-y-0.5">
                        <a asp-action="Index" class="block px-3 py-1.5 rounded-lg text-sm transition-colors @(ViewBag.CurrentCategory == null ? "bg-primary/10 text-primary font-medium" : "hover:bg-base-300/50 opacity-70 hover:opacity-100")">
                            Tất cả
                        </a>
                        @if (categories != null)
                        {
                            @foreach (var cat in categories)
                            {
                                <a asp-action="Index" asp-route-category="@cat.Slug"
                                   class="block px-3 py-1.5 rounded-lg text-sm transition-colors @(ViewBag.CurrentCategory == cat.Slug ? "bg-primary/10 text-primary font-medium" : "hover:bg-base-300/50 opacity-70 hover:opacity-100")">
                                    @cat.Name
                                </a>
                            }
                        }
                    </div>
                </div>

                <!-- Price filter -->
                <div>
                    <h4 class="text-xs font-semibold uppercase tracking-wider opacity-50 mb-3">Khoảng giá</h4>
                    <div class="space-y-1.5" id="price-filter">
                        @{
                            var priceRanges = new[] {
                                (Min: (decimal?)null, Max: (decimal?)5000000, Label: "Dưới 5 triệu"),
                                (Min: (decimal?)5000000, Max: (decimal?)10000000, Label: "5 - 10 triệu"),
                                (Min: (decimal?)10000000, Max: (decimal?)20000000, Label: "10 - 20 triệu"),
                                (Min: (decimal?)20000000, Max: (decimal?)40000000, Label: "20 - 40 triệu"),
                                (Min: (decimal?)40000000, Max: (decimal?)null, Label: "Trên 40 triệu")
                            };
                            var currentMin = ViewBag.MinPrice as decimal?;
                            var currentMax = ViewBag.MaxPrice as decimal?;
                        }
                        <a asp-action="Index" asp-route-category="@ViewBag.CurrentCategory" asp-route-brand="@ViewBag.CurrentBrand" asp-route-search="@ViewBag.CurrentSearch" asp-route-sort="@ViewBag.CurrentSort"
                           class="block px-3 py-1.5 rounded-lg text-sm transition-colors @(currentMin == null && currentMax == null ? "bg-primary/10 text-primary font-medium" : "hover:bg-base-300/50 opacity-70 hover:opacity-100")">
                            Tất cả
                        </a>
                        @foreach (var range in priceRanges)
                        {
                            var isActive = currentMin == range.Min && currentMax == range.Max;
                            <a asp-action="Index" asp-route-category="@ViewBag.CurrentCategory" asp-route-brand="@ViewBag.CurrentBrand" asp-route-search="@ViewBag.CurrentSearch" asp-route-sort="@ViewBag.CurrentSort"
                               asp-route-minPrice="@range.Min" asp-route-maxPrice="@range.Max"
                               class="block px-3 py-1.5 rounded-lg text-sm transition-colors @(isActive ? "bg-primary/10 text-primary font-medium" : "hover:bg-base-300/50 opacity-70 hover:opacity-100")">
                                @range.Label
                            </a>
                        }
                    </div>
                </div>

                <!-- Brands -->
                @if (brands != null && brands.Any())
                {
                    <div>
                        <h4 class="text-xs font-semibold uppercase tracking-wider opacity-50 mb-3">Thương hiệu</h4>
                        <div class="space-y-0.5">
                            <a asp-action="Index" asp-route-category="@ViewBag.CurrentCategory"
                               class="block px-3 py-1.5 rounded-lg text-sm transition-colors @(ViewBag.CurrentBrand == null ? "bg-primary/10 text-primary font-medium" : "hover:bg-base-300/50 opacity-70 hover:opacity-100")">
                                Tất cả
                            </a>
                            @foreach (var b in brands)
                            {
                                <a asp-action="Index" asp-route-category="@ViewBag.CurrentCategory" asp-route-brand="@b"
                                   class="block px-3 py-1.5 rounded-lg text-sm transition-colors @(ViewBag.CurrentBrand == b ? "bg-primary/10 text-primary font-medium" : "hover:bg-base-300/50 opacity-70 hover:opacity-100")">
                                    @b
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </aside>

        <!-- Product grid -->
        <div class="flex-1 min-w-0">
            <!-- Sort bar -->
            <div class="flex items-center justify-between mb-6 pb-4 border-b border-base-300/30">
                <p class="text-sm opacity-50">
                    <span class="font-semibold text-base-content opacity-100">@ViewBag.TotalItems</span> sản phẩm
                </p>
                @{
                    var sortOptions = new[] {
                        (Value: (string?)null, Label: "Mới nhất"),
                        (Value: (string?)"price-asc", Label: "Giá tăng dần"),
                        (Value: (string?)"price-desc", Label: "Giá giảm dần"),
                        (Value: (string?)"name", Label: "Tên A-Z")
                    };
                }
                <select class="select select-bordered select-sm bg-base-200/60 min-w-[140px]"
                        onchange="window.location.href=this.value">
                    @foreach (var opt in sortOptions)
                    {
                        var url = Url.Action("Index", new { category = ViewBag.CurrentCategory, brand = ViewBag.CurrentBrand, search = ViewBag.CurrentSearch, sort = opt.Value, minPrice = ViewBag.MinPrice, maxPrice = ViewBag.MaxPrice });
                        var isSelected = (string?)ViewBag.CurrentSort == opt.Value;
                        <option value="@url" selected="@isSelected">@opt.Label</option>
                    }
                </select>
            </div>

            <div id="product-grid">
                @await Html.PartialAsync("_ProductGrid", Model)
            </div>

            <!-- Pagination -->
            @await Html.PartialAsync("~/Views/Shared/Partials/_Pagination.cshtml",
                (ViewBag.CurrentPage as int? ?? 1,
                 ViewBag.TotalPages as int? ?? 1,
                 "Index", "Product",
                 new Dictionary<string, string>
                 {
                     ["category"] = ViewBag.CurrentCategory ?? "",
                     ["brand"] = ViewBag.CurrentBrand ?? "",
                     ["search"] = ViewBag.CurrentSearch ?? "",
                     ["sort"] = ViewBag.CurrentSort ?? "",
                     ["minPrice"] = ViewBag.MinPrice?.ToString() ?? "",
                     ["maxPrice"] = ViewBag.MaxPrice?.ToString() ?? ""
                 }))
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    const input = document.getElementById('product-search');
    if (!input) return;
    let timer;
    input.addEventListener('input', function() {
        clearTimeout(timer);
        timer = setTimeout(function() {
            const url = new URL(window.location.href);
            if (input.value) url.searchParams.set('search', input.value);
            else url.searchParams.delete('search');
            url.searchParams.delete('page');
            window.location.href = url.toString();
        }, 400);
    });
})();
</script>
}
